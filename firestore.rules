rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Entidades: lectura publica, escritura solo autenticados
    match /entidades/{entidadId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(["nombre"]);
      allow delete: if false;
    }

    // Fuentes: lectura publica, escritura solo autenticados
    match /fuentes/{fuenteId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(["url", "tipo", "entidadId", "estado", "createdAt"]);
      allow delete: if false;
    }

    // Evaluaciones: lectura publica, escritura solo admin/scripts
    match /evaluaciones/{evaluacionId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
