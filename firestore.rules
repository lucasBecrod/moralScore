rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Entidades: lectura publica, escritura solo autenticados
    match /entidades/{entidadId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(["nombre"]);
      allow delete: if false;
    }

    // Fuentes: lectura publica, escritura solo autenticados
    match /fuentes/{fuenteId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(["url", "tipo", "entidadId", "estado", "createdAt"]);
      allow delete: if false;
    }

    // Evaluaciones: lectura publica, creacion solo admin/scripts, update de validacionesCiudadanas autenticado
    match /evaluaciones/{evaluacionId} {
      allow read: if true;
      allow create: if false;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["validacionesCiudadanas"]);
      allow delete: if false;
    }

    // Candidaturas: lectura publica, escritura solo autenticados
    match /candidaturas/{candidaturaId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Procesos electorales: solo lectura (gestion via scripts)
    match /procesos/{procesoId} {
      allow read: if true;
      allow write: if false;
    }

    // Validaciones ciudadanas: create/delete solo el propio usuario
    match /validaciones/{validacionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && validacionId.matches(request.auth.uid + '_.*');
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Metricas: escritura publica (counters anonimos), sin lectura publica
    match /metricas/{docId} {
      allow read: if false;
      allow create, update: if true;
      allow delete: if false;
    }
  }
}
