rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Entidades: lectura pública, creación con campos obligatorios, update/delete solo admin
    match /entidades/{entidadId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(["nombre"]);
      allow delete: if false;
    }

    // Fuentes: lectura pública, creación pública (solo pendiente), update/delete admin
    match /fuentes/{fuenteId} {
      allow read: if true;
      allow create: if
        request.resource.data.estado == "pendiente" &&
        request.resource.data.creadaPor == "publico" &&
        request.resource.data.keys().hasAll(["url", "tipo", "entidadId", "estado", "createdAt"]);
      allow update, delete: if false; // solo desde consola o scripts locales
    }

    // Evaluaciones: lectura pública, escritura solo admin (consola Firebase)
    match /evaluaciones/{evaluacionId} {
      allow read: if true;
      allow write: if false; // Lucas y Lady suben desde consola o scripts locales
    }
  }
}
