# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# firebase service account keys (NEVER commit)
*-adminsdk-*.json
*-firebase-*.json
service-account*.json

# cached images (regenerate with: npx tsx scripts/cache-images.ts)
public/img/entidades/
public/img/partidos/

# generated docs — NO ignorar, se necesitan en deploy
# public/docs/

# firebase emulator logs
firebase-debug.log
firestore-debug.log
ui-debug.log

# playwright
.playwright-mcp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
